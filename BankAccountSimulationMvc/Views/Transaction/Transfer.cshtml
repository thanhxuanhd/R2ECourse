@model BankAccountSimulationMvc.Models.TransferViewModel

@{
    ViewData["Title"] = "Transfer Funds";
}

<div class="row mt-5">
    <div class="col-lg-6 offset-lg-3">
        <div class="card premium-card border-0">
            <div class="card-header gradient-header">
                <div class="d-flex align-items-center">
                    <div class="bg-white bg-opacity-25 p-2 rounded-3 me-3">
                        <i class="bi bi-arrow-left-right fs-4"></i>
                    </div>
                    <h4 class="mb-0">Transfer Funds</h4>
                </div>
            </div>
            <div class="card-body p-4 p-md-5">
                <form asp-action="Transfer" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm" role="alert"></div>

                    <input type="hidden" asp-for="FromAccountNumber" />

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label info-label">From Account</label>
                            <div class="info-value text-primary font-monospace">@Model.FromAccountNumber</div>
                        </div>
                        <div class="col-md-6 text-md-end">
                            <label class="form-label info-label">Available Balance</label>
                            <div class="info-value">@Model.Balance.ToString("C")</div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ToAccountNumber" class="form-label info-label">To Account Number</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-person-check"></i></span>
                            <input asp-for="ToAccountNumber" class="form-control border-start-0" placeholder="Enter target account number" />
                        </div>
                        <span asp-validation-for="ToAccountNumber" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Amount" class="form-label info-label">Transfer Amount</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-light border-end-0">@System.Globalization.CultureInfo.CurrentCulture.NumberFormat.CurrencySymbol</span>
                            <input asp-for="Amount" class="form-control border-start-0 fw-bold" placeholder="0.00" type="number" step="0.01" min="0.01" />
                        </div>
                        <span asp-validation-for="Amount" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label info-label">Description (Optional)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-chat-left-dots"></i></span>
                            <input asp-for="Description" class="form-control border-start-0" placeholder="e.g. Loan repayment, Gift" />
                        </div>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-3 justify-content-end mt-5">
                        <a asp-controller="Account" asp-action="Details" asp-route-id="@Model.FromAccountNumber" class="btn btn-premium btn-premium-outline">
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-primary btn-premium shadow">
                            <i class="bi bi-send me-2"></i> Confirm Transfer
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

