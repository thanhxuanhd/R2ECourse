@model BankAccountSimulationMvc.Models.EditAccountViewModel

@{
    ViewData["Title"] = "Edit Account";
}

<div class="row mt-5">
    <div class="col-lg-6 offset-lg-3">
        <div class="card premium-card border-0">
            <div class="card-header gradient-header">
                <div class="d-flex align-items-center">
                    <div class="bg-white bg-opacity-25 p-2 rounded-3 me-3">
                        <i class="bi bi-pencil-square fs-4"></i>
                    </div>
                    <h4 class="mb-0">Edit Account</h4>
                </div>
            </div>
            <div class="card-body p-4 p-md-5">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm" role="alert"></div>
                    <input type="hidden" asp-for="AccountNumber" />
                    
                    <div class="mb-4">
                        <label asp-for="AccountNumber" class="form-label info-label">Account Number</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-hash"></i></span>
                            <input class="form-control border-start-0 bg-white" value="@Model.AccountNumber" disabled />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="OwnerName" class="form-label info-label">Owner Name</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-person"></i></span>
                            <input asp-for="OwnerName" class="form-control border-start-0" placeholder="Enter owner's full name" />
                        </div>
                        <span asp-validation-for="OwnerName" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Status" class="form-label info-label">Account Status</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-shield-check"></i></span>
                            <select asp-for="Status" class="form-select border-start-0" asp-items="Html.GetEnumSelectList<BankAccountSimulationMvc.Models.AccountStatus>()"></select>
                        </div>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-3 justify-content-end mt-5">
                        <a asp-action="Index" class="btn btn-premium btn-premium-outline">
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-primary btn-premium shadow">
                            <i class="bi bi-save me-2"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

