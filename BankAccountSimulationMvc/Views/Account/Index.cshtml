@model BankAccountSimulationMvc.Models.AccountIndexViewModel
@using BankAccountSimulationMvc.Models

@{
    ViewData["Title"] = "Accounts List";
}

<div class="row mt-5 mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-0">Accounts Management</h2>
            <p class="text-muted">Manage and monitor customer bank accounts</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-premium shadow-sm">
            <i class="bi bi-plus-circle me-2"></i> Create New Account
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card premium-card border-0 mb-4">
    <div class="card-body p-4">
        <form asp-action="Index" method="get">
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label for="searchString" class="form-label info-label">Search Accounts</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="searchString" id="searchString" class="form-control border-start-0" value="@Model.SearchString" placeholder="Account Number or Owner Name..." />
                    </div>
                </div>
                <div class="col-md-4">
                    <label for="statusFilter" class="form-label info-label">Status Filter</label>
                    <select name="statusFilter" id="statusFilter" class="form-select" asp-items="Model.StatusList">
                        <option value="">All Statuses</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-premium btn-premium-outline w-100">
                        Filter
                    </button>
                    <a asp-action="Index" class="btn btn-premium btn-premium-outline w-100 bg-light">
                        Clear
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card premium-card border-0 overflow-hidden">
    <div class="card-header gradient-header py-3">
        <div class="d-flex align-items-center">
            <i class="bi bi-list-ul me-2 fs-5"></i>
            <h5 class="mb-0">Account List</h5>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">Account Number</th>
                    <th>Owner Name</th>
                    <th>Balance</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Accounts != null && Model.Accounts.Any())
                {
                    @foreach (var item in Model.Accounts)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold font-monospace text-primary">@item.AccountNumber</span>
                            </td>
                            <td>
                                <div class="fw-semibold">@item.OwnerName</div>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@item.Balance.ToString("C")</div>
                            </td>
                            <td>
                                <span class="status-badge @(item.Status == AccountStatus.Active ? "status-active" : "status-frozen")" style="font-size: 0.75rem; padding: 0.25rem 0.75rem;">
                                    @item.Status
                                </span>
                            </td>
                            <td>
                                <div class="text-muted small">@item.CreatedAt.ToString("MMM dd, yyyy")</div>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a asp-action="Details" asp-route-id="@item.AccountNumber" class="btn btn-sm btn-outline-primary btn-premium me-1" title="Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.AccountNumber" class="btn btn-sm btn-outline-secondary btn-premium me-1" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <button class="btn btn-sm btn-outline-dark btn-premium dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-2">
                                        @if (item.Status == AccountStatus.Active)
                                        {
                                            <li><a class="dropdown-item rounded py-2" asp-controller="Transaction" asp-action="Deposit" asp-route-accountId="@item.AccountNumber"><i class="bi bi-arrow-down-circle text-success me-2"></i> Deposit</a></li>
                                            <li><a class="dropdown-item rounded py-2" asp-controller="Transaction" asp-action="Withdraw" asp-route-accountId="@item.AccountNumber"><i class="bi bi-arrow-up-circle text-warning me-2"></i> Withdraw</a></li>
                                            <li><a class="dropdown-item rounded py-2" asp-controller="Transaction" asp-action="Transfer" asp-route-accountId="@item.AccountNumber"><i class="bi bi-arrow-left-right text-primary me-2"></i> Transfer</a></li>
                                            <li><hr class="dropdown-divider"></li>
                                        }
                                        <li>
                                            <form asp-action="ToggleStatus" asp-route-id="@item.AccountNumber" method="post">
                                                <button type="submit" class="dropdown-item rounded py-2 @(item.Status == AccountStatus.Active ? "text-danger" : "text-success")">
                                                    @if (item.Status == AccountStatus.Active)
                                                    {
                                                        <i class="bi bi-snow me-2"></i> <span>Freeze Account</span>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-lightning-fill me-2"></i> <span>Activate Account</span>
                                                    }
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <div class="mb-2"><i class="bi bi-inbox fs-1 opacity-25"></i></div>
                            <p>No accounts found matching your criteria.</p>
                            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear Filters</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

